{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["esnext"],
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "moduleResolution": "node",
    "outDir": "./lib/",
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": false,
    "resolveJsonModule": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "incremental": true,
    "paths": {
      "@uwu/helper-validator-identifier": [
        "./packages/babel-helper-validator-identifier/src"
      ],
      "@uwu/parser": ["./packages/babel-parser/src"],
      "@babel/helper-string-parser": [
        "./packages/babel-helper-string-parser/src"
      ]
    }
  },
  "exclude": ["**/test/"],
  "include": ["./index.ts"]
}
